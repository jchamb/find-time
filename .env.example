# Cloudflare Worker sync backend URL
# Local dev: ws://localhost:8787
# Staging/Prod: wss://your-worker.your-account.workers.dev
VITE_LIVESTORE_SYNC_URL=ws://localhost:8787

# Dev token for local Cloudflare worker auth (replace with a secure random token)
VITE_LIVESTORE_SYNC_AUTH_TOKEN=replace-with-secure-random-token
